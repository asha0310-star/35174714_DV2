{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Malaysia and Indonesia drove global palm oil growth",
    "subtitle": [
      "Production by group, 1961–2023; units: million tonnes.",
      "“Other” aggregates remaining producers."
    ]
  },
  "width": "container",
  "height": 420,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "data/palm_production_long.csv"
  },
  "transform": [
    {
      "filter": "datum.Entity !== 'World'"
    },
    {
      "calculate": "datum['Palm oil - Production (tonnes)'] / 1e6",
      "as": "Production_Mt_raw"
    },
    {
      "calculate": "datum.Entity === 'Malaysia' || datum.Entity === 'Indonesia' ? datum.Entity : 'Other'",
      "as": "Group"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "Production_Mt_raw",
          "as": "Production_Mt"
        }
      ],
      "groupby": [
        "Year",
        "Group"
      ]
    },
    {
      "calculate": "datetime(toNumber(datum.Year), 0, 1)",
      "as": "year_date"
    }
  ],
  "params": [
    {
      "name": "year_link",
      "value": 2006
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3.2,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year_date",
          "type": "temporal",
          "title": null,
          "axis": {
            "format": "%Y",
            "tickCount": 9,
            "labelAngle": 0,
            "labelOverlap": "greedy",
            "labelColor": "#3a4540",
            "domain": true,
            "grid": false
          },
          "scale": {
            "domain": [
              "1961-01-01",
              "2023-01-01"
            ]
          }
        },
        "y": {
          "field": "Production_Mt",
          "type": "quantitative",
          "title": "Production (Million Tonnes)",
          "axis": {
            "grid": true,
            "gridColor": "#eeeeee",
            "titleAngle": 270
          },
          "scale": {
            "zero": true
          }
        },
        "color": {
          "field": "Group",
          "type": "nominal",
          "scale": {
            "domain": [
              "Malaysia",
              "Indonesia",
              "Other"
            ],
            "range": [
              "#c25e1e",
              "#2d5a3d",
              "#8f9792"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "Group",
            "type": "nominal"
          },
          {
            "field": "Year",
            "type": "quantitative",
            "format": "d"
          },
          {
            "field": "Production_Mt",
            "type": "quantitative",
            "format": ".2f",
            "title": "Production (Mt)"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 12,
        "fontWeight": 700,
        "font": "Inter"
      },
      "encoding": {
        "x": {
          "field": "year_date",
          "type": "temporal",
          "scale": {
            "domain": [
              "1961-01-01",
              "2023-01-01"
            ]
          },
          "axis": {
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "Production_Mt",
          "type": "quantitative",
          "title": "Production (Million Tonnes)",
          "axis": {
            "gridColor": "#eeeeee"
          },
          "scale": {
            "zero": true
          }
        },
        "text": {
          "field": "Group"
        },
        "color": {
          "field": "Group",
          "type": "nominal",
          "scale": {
            "domain": [
              "Malaysia",
              "Indonesia",
              "Other"
            ],
            "range": [
              "#c25e1e",
              "#2d5a3d",
              "#8f9792"
            ]
          },
          "legend": null
        }
      }
    },
    {
      "data": {
        "values": [
          {}
        ]
      },
      "transform": [
        {
          "calculate": "datetime(year_link, 0, 1)",
          "as": "rule_x"
        }
      ],
      "mark": {
        "type": "rule",
        "color": "#4b5563",
        "strokeWidth": 1,
        "opacity": 0.55,
        "strokeDash": [
          4,
          3
        ]
      },
      "encoding": {
        "x": {
          "field": "rule_x",
          "type": "temporal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x": "1998-01-01",
            "y": 46,
            "label": "Indonesia overtakes\nMalaysia, 2006"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 0,
        "dy": -8,
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": 700,
        "lineBreak": "\n",
        "color": "#4b5563"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "temporal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "domain": true,
      "ticks": false,
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleFontWeight": 500,
      "titleColor": "#1f2421",
      "grid": false,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    }
  },
  "padding": {
    "top": 12,
    "right": 82,
    "bottom": 32,
    "left": 8
  }
}