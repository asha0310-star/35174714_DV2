{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Palm oil land expansion is country-led",
    "subtitle": "Area harvested for oil palm, 1961 → 2023; units: million hectares.",
    "anchor": "start"
  },
  "width": "container",
  "height": 420,
  "padding": {
    "right": 125,
    "bottom": 34,
    "top": 18,
    "left": 8
  },
  "data": {
    "url": "data/landuse_slope.csv"
  },
  "transform": [
    {
      "filter": "datum.Year == 1961 || datum.Year == 2023"
    },
    {
      "filter": "datum.Entity != 'Low-income countries' && datum.Entity != 'Lower-middle-income countries' && datum.Entity != 'Upper-middle-income countries'"
    },
    {
      "calculate": "datum['Palm fruit oil - Area harvested (hectares)'] / 1e6",
      "as": "Area_Mha"
    },
    {
      "calculate": "datum.Entity === 'Malaysia' || datum.Entity === 'Indonesia' ? datum.Entity : 'Other countries'",
      "as": "Group"
    },
    {
      "calculate": "format(datum.Area_Mha, '.2f') + ' Mha'",
      "as": "area_label"
    },
    {
      "calculate": "datum.Year == 1961 ? datum.Area_Mha : null",
      "as": "area_1961_candidate"
    },
    {
      "calculate": "datum.Year == 2023 ? datum.Area_Mha : null",
      "as": "area_2023_candidate"
    },
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "area_1961_candidate",
          "as": "area_1961_Mha"
        },
        {
          "op": "max",
          "field": "area_2023_candidate",
          "as": "area_2023_Mha"
        }
      ],
      "groupby": [
        "Entity"
      ]
    },
    {
      "calculate": "datum.area_2023_Mha - datum.area_1961_Mha",
      "as": "area_change_Mha"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "point": {
          "size": 95,
          "filled": true
        }
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": null,
          "axis": {
            "orient": "top",
            "labelFontSize": 15,
            "labelFontWeight": "bold",
            "labelColor": "#333333",
            "labelFont": "Inter"
          }
        },
        "y": {
          "field": "Area_Mha",
          "type": "quantitative",
          "title": null,
          "axis": {
            "grid": true,
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "color": {
          "field": "Group",
          "type": "nominal",
          "scale": {
            "domain": [
              "Malaysia",
              "Indonesia",
              "Other countries"
            ],
            "range": [
              "#c25e1e",
              "#2d5a3d",
              "#8f9792"
            ]
          },
          "legend": null
        },
        "detail": {
          "field": "Entity"
        },
        "tooltip": [
          {
            "field": "Entity",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "area_1961_Mha",
            "type": "quantitative",
            "format": ".2f",
            "title": "1961 area (Mha)"
          },
          {
            "field": "area_2023_Mha",
            "type": "quantitative",
            "format": ".2f",
            "title": "2023 area (Mha)"
          },
          {
            "field": "area_change_Mha",
            "type": "quantitative",
            "format": "+.2f",
            "title": "Change (Mha)"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Year == 2023 && indexof(['Indonesia','Malaysia','Nigeria','Thailand'], datum.Entity) >= 0"
        },
        {
          "calculate": "datum.Entity + '  ' + datum.area_label",
          "as": "right_label"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "font": "Inter",
        "fontSize": 11,
        "fill": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },
        "y": {
          "field": "Area_Mha",
          "type": "quantitative",
          "title": null,
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "text": {
          "field": "right_label",
          "type": "nominal"
        },
        "color": {
          "field": "Group",
          "type": "nominal",
          "scale": {
            "domain": [
              "Malaysia",
              "Indonesia",
              "Other countries"
            ],
            "range": [
              "#c25e1e",
              "#2d5a3d",
              "#8f9792"
            ]
          },
          "legend": null
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleFontWeight": 500,
      "titleColor": "#1f2421",
      "grid": true,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  }
}
