{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Is each tonne of palm oil costing less forest?",
    "subtitle": [
      "Tree-cover loss per million tonnes of CPO (kha / Mt).",
      "Lower is better; colour bands show high, moderate, and improving values."
    ],
    "anchor": "start"
  },
  "width": "container",
  "height": 320,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "top": 18,
    "bottom": 38,
    "left": 8,
    "right": 72
  },
  "data": {
    "url": "data/malaysia_economy_yearly.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum.forest_loss_kha)",
      "as": "loss_num"
    },
    {
      "calculate": "toNumber(datum.cpo_production_Mt)",
      "as": "prod_num"
    },
    {
      "calculate": "datum.loss_num / datum.prod_num",
      "as": "efficiency"
    },
    {
      "calculate": "datum.efficiency > 30 ? 'High cost (>30)' : (datum.efficiency >= 20 ? 'Moderate (20–30)' : 'Improving (<20)')",
      "as": "band"
    }
  ],
  "layer": [
    {
      "data": {
        "values": [
          {
            "y0": 0,
            "y1": 20,
            "band": "Improving (<20)"
          },
          {
            "y0": 20,
            "y1": 30,
            "band": "Moderate (20–30)"
          },
          {
            "y0": 30,
            "y1": 60,
            "band": "High cost (>30)"
          }
        ]
      },
      "mark": {
        "type": "rect",
        "opacity": 0.07
      },
      "encoding": {
        "y": {
          "field": "y0",
          "type": "quantitative"
        },
        "y2": {
          "field": "y1"
        },
        "color": {
          "field": "band",
          "type": "nominal",
          "scale": {
            "domain": [
              "High cost (>30)",
              "Moderate (20–30)",
              "Improving (<20)"
            ],
            "range": [
              "#b22222",
              "#c25e1e",
              "#2d5a3d"
            ]
          },
          "legend": {
            "orient": "bottom",
            "title": "Efficiency band"
          }
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 1.5,
        "color": "#6b7570",
        "opacity": 0.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "axis": {
            "labelAngle": 0,
            "labelOverlap": "greedy",
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "efficiency",
          "type": "quantitative",
          "title": null,
          "scale": {
            "domain": [
              0,
              50
            ]
          },
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 110,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "efficiency",
          "type": "quantitative",
          "title": null,
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "color": {
          "field": "band",
          "type": "nominal",
          "scale": {
            "domain": [
              "High cost (>30)",
              "Moderate (20–30)",
              "Improving (<20)"
            ],
            "range": [
              "#b22222",
              "#c25e1e",
              "#2d5a3d"
            ]
          },
          "legend": {
            "orient": "bottom",
            "title": "Efficiency band"
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "efficiency",
            "type": "quantitative",
            "format": ".1f",
            "title": "kha / Mt"
          },
          {
            "field": "forest_loss_kha",
            "type": "quantitative",
            "format": ".1f",
            "title": "Forest loss (kha)"
          },
          {
            "field": "cpo_production_Mt",
            "type": "quantitative",
            "format": ".2f",
            "title": "CPO (Mt)"
          },
          {
            "field": "band",
            "type": "nominal",
            "title": "Band"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "year": "2022",
            "y": 13.45,
            "y2": 18.5
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#4b5563",
        "strokeWidth": 1,
        "opacity": 0.65
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "y2": {
          "field": "y2",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": "2022",
            "y": 18.5,
            "label": "Best recent\n13 kha/Mt"
          }
        ]
      },
      "mark": {
        "type": "text",
        "dy": -4,
        "fontSize": 11,
        "fontWeight": 700,
        "font": "Inter",
        "lineBreak": "\n",
        "color": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": "2014",
            "y": 33.0,
            "label": "Worst year\n33 kha/Mt"
          }
        ]
      },
      "mark": {
        "type": "text",
        "dx": 8,
        "dy": -10,
        "align": "left",
        "fontSize": 11,
        "fontWeight": 700,
        "font": "Inter",
        "lineBreak": "\n",
        "color": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleFontWeight": 500,
      "titleColor": "#1f2421",
      "grid": true,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421",
      "labelColor": "#3a4540"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    }
  }
}
