{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Peninsula produces more oil from less land",
    "subtitle": "Share of Malaysia’s 2025 total. Grey = planted area; orange = CPO output.",
    "anchor": "start"
  },
  "width": "container",
  "height": 300,
  "data": {
    "url": "data/state_cpo_2025.csv"
  },
  "transform": [
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "cpo_production_t",
          "as": "total_cpo_t"
        },
        {
          "op": "sum",
          "field": "planted_area_ha",
          "as": "total_area_ha"
        }
      ]
    },
    {
      "calculate": "datum.cpo_production_t / datum.total_cpo_t * 100",
      "as": "cpo_share_pct"
    },
    {
      "calculate": "datum.planted_area_ha / datum.total_area_ha * 100",
      "as": "area_share_pct"
    },
    {
      "calculate": "datum.cpo_production_t / datum.planted_area_ha",
      "as": "yield_t_per_ha"
    },
    {
      "calculate": "format(datum.yield_t_per_ha, '.2f') + ' t/ha'",
      "as": "yield_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 5,
        "color": "#b8c0bb"
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "sort": [
            "Peninsular Malaysia",
            "Sarawak",
            "Sabah"
          ],
          "title": null
        },
        "x": {
          "field": "area_share_pct",
          "type": "quantitative",
          "title": "Share of Malaysia total (%)",
          "scale": {
            "domain": [
              0,
              60
            ]
          },
          "axis": {
            "format": ".0f",
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "x2": {
          "field": "cpo_share_pct"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 180,
        "color": "#6b7570",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "sort": [
            "Peninsular Malaysia",
            "Sarawak",
            "Sabah"
          ]
        },
        "x": {
          "field": "area_share_pct",
          "type": "quantitative",
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "tooltip": [
          {
            "field": "region"
          },
          {
            "field": "area_share_pct",
            "type": "quantitative",
            "format": ".1f",
            "title": "Planted area share (%)"
          },
          {
            "field": "yield_t_per_ha",
            "type": "quantitative",
            "format": ".2f",
            "title": "Yield (t/ha)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 220,
        "color": "#c25e1e",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "sort": [
            "Peninsular Malaysia",
            "Sarawak",
            "Sabah"
          ]
        },
        "x": {
          "field": "cpo_share_pct",
          "type": "quantitative",
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "tooltip": [
          {
            "field": "region"
          },
          {
            "field": "cpo_share_pct",
            "type": "quantitative",
            "format": ".1f",
            "title": "CPO output share (%)"
          },
          {
            "field": "yield_t_per_ha",
            "type": "quantitative",
            "format": ".2f",
            "title": "Yield (t/ha)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#1f2421"
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "sort": [
            "Peninsular Malaysia",
            "Sarawak",
            "Sabah"
          ]
        },
        "x": {
          "field": "cpo_share_pct",
          "type": "quantitative",
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "text": {
          "field": "yield_label"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleFontWeight": 500,
      "titleColor": "#1f2421",
      "grid": true,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "top": 42,
    "right": 55,
    "bottom": 28,
    "left": 8
  }
}
