{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where Malaysia's palm oil exports went in 2025",
    "subtitle": [
      "Top seven importers bought 7.86 Mt, or 51.5% of Malaysia palm oil exports.",
      "Ribbon thickness = export volume; labels show each market share of total palm oil exports."
    ],
    "anchor": "start"
  },
  "width": "container",
  "height": 360,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "top": 24,
    "bottom": 24,
    "left": 95,
    "right": 120
  },
  "data": {
    "url": "data/imports_flows.csv"
  },
  "transform": [
    {
      "calculate": "datum.country + ' (' + format(datum.share_pct, '.1f') + '%)'",
      "as": "country_label"
    }
  ],
  "params": [
    {
      "name": "destination_select",
      "value": "All",
      "bind": {
        "input": "select",
        "options": [
          "All",
          "India",
          "Kenya",
          "European Union",
          "China",
          "Türkiye",
          "Philippines",
          "Japan"
        ],
        "name": "Highlight importer: "
      }
    }
  ],
  "encoding": {
    "x": {
      "field": "x",
      "type": "quantitative",
      "axis": null,
      "scale": {
        "domain": [
          -5,
          105
        ]
      }
    },
    "y": {
      "field": "y",
      "type": "quantitative",
      "axis": null,
      "scale": {
        "domain": [
          0.3,
          7.7
        ],
        "reverse": true
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "opacity": 0.72
      },
      "encoding": {
        "opacity": {
          "condition": {
            "test": "destination_select === 'All' || datum.country === destination_select",
            "value": 0.92
          },
          "value": 0.1
        },
        "detail": {
          "field": "country",
          "type": "nominal"
        },
        "order": {
          "field": "order",
          "type": "ordinal"
        },
        "size": {
          "field": "volume_Mt",
          "type": "quantitative",
          "scale": {
            "range": [
              3,
              34
            ]
          },
          "legend": {
            "title": "Ribbon volume (Mt)",
            "orient": "top",
            "values": [
              0.5,
              1.5,
              2.5
            ]
          }
        },
        "color": {
          "value": "#c25e1e"
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Destination"
          },
          {
            "field": "volume_Mt",
            "type": "quantitative",
            "format": ".2f",
            "title": "Volume (Mt)"
          },
          {
            "field": "share_pct",
            "type": "quantitative",
            "format": ".1f",
            "title": "Share of exports (%)"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.point == 'source'"
        },
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "volume_Mt",
              "as": "total"
            }
          ],
          "groupby": [
            "x",
            "y"
          ]
        }
      ],
      "mark": {
        "type": "circle",
        "color": "#c25e1e",
        "size": 600,
        "opacity": 0.92,
        "stroke": "#1f2421",
        "strokeWidth": 1
      },
      "encoding": {}
    },
    {
      "data": {
        "values": [
          {
            "x": -3,
            "y": 3.55,
            "label": "Malaysia"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "dy": -8,
        "fontSize": 14,
        "fontWeight": 700,
        "font": "Fraunces",
        "color": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x": -3,
            "y": 4.35,
            "label": "15.27 Mt total exports"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "dy": 28,
        "fontSize": 10.5,
        "fontStyle": "italic",
        "font": "Inter",
        "color": "#3a4540",
        "opacity": 0.95
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.point == 'dest'"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 90,
        "opacity": 0.95
      },
      "encoding": {
        "opacity": {
          "condition": {
            "test": "destination_select === 'All' || datum.country === destination_select",
            "value": 0.95
          },
          "value": 0.12
        },
        "color": {
          "value": "#2d5a3d"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.point == 'dest'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 12,
        "fontSize": 12,
        "fontWeight": 600,
        "font": "Inter",
        "color": "#1f2421"
      },
      "encoding": {
        "opacity": {
          "condition": {
            "test": "destination_select === 'All' || datum.country === destination_select",
            "value": 1
          },
          "value": 0.18
        },
        "text": {
          "field": "country_label",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.point == 'dest'"
        },
        {
          "calculate": "format(datum.volume_Mt, '.2f') + ' Mt'",
          "as": "vol_label"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 12,
        "dy": 16,
        "fontSize": 10.5,
        "fontStyle": "italic",
        "font": "Inter",
        "color": "#3a4540"
      },
      "encoding": {
        "opacity": {
          "condition": {
            "test": "destination_select === 'All' || datum.country === destination_select",
            "value": 0.95
          },
          "value": 0.12
        },
        "text": {
          "field": "vol_label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421",
      "labelColor": "#3a4540"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    },
    "axis": {
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421",
      "titleFontWeight": 500,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    }
  }
}
