{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Forest loss peaked before planted area fully plateaued",
    "subtitle": "Connected annual path, 2001\u20132024. X = MPOB planted area; Y = GFW tree-cover loss."
  },
  "width": "container",
  "height": 520,
  "data": {
    "url": "data/area_vs_loss_yearly.csv"
  },
  "transform": [
    {
      "calculate": "datum.year == 2014 ? 'Peak loss: 2014' : datum.year == 2019 ? 'Largest area: 2019' : datum.year == 2024 ? 'Recent: 2024' : ''",
      "as": "label"
    },
    {
      "calculate": "datum.year == 2014 || datum.year == 2019 || datum.year == 2024",
      "as": "key_year"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": false,
        "strokeWidth": 2.5,
        "color": "#7a8580"
      },
      "encoding": {
        "x": {
          "field": "planted_area_Mha",
          "type": "quantitative",
          "scale": {
            "zero": false,
            "nice": false
          },
          "axis": {
            "title": "Oil palm planted area (million hectares)",
            "grid": true
          }
        },
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative",
          "axis": {
            "title": "Tree-cover loss (thousand hectares)",
            "grid": true
          }
        },
        "order": {
          "field": "year",
          "type": "ordinal"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 105,
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "planted_area_Mha",
          "type": "quantitative"
        },
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative"
        },
        "color": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "scheme": "oranges"
          },
          "legend": {
            "title": "Year"
          }
        },
        "opacity": {
          "condition": {
            "test": "datum.key_year",
            "value": 1
          },
          "value": 0.72
        },
        "size": {
          "condition": {
            "test": "datum.key_year",
            "value": 180
          },
          "value": 75
        },
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "format": "d",
            "title": "Year"
          },
          {
            "field": "planted_area_Mha",
            "type": "quantitative",
            "format": ".2f",
            "title": "Planted area (Mha)"
          },
          {
            "field": "forest_loss_kha",
            "type": "quantitative",
            "format": ".1f",
            "title": "Tree-cover loss (000 ha)"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.key_year"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": 700,
        "align": "left",
        "baseline": "middle",
        "dx": 10,
        "color": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "planted_area_Mha",
          "type": "quantitative"
        },
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "planted_area_Mha": 5.72,
            "forest_loss_kha": 360,
            "note": "Path direction: 2001 \u2192 2024"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 13,
        "fontWeight": 700,
        "align": "left",
        "color": "#c25e1e"
      },
      "encoding": {
        "x": {
          "field": "planted_area_Mha",
          "type": "quantitative"
        },
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative"
        },
        "text": {
          "field": "note"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "planted_area_Mha": 5.39,
            "forest_loss_kha": 681.62
          }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [
          4,
          4
        ],
        "color": "#c25e1e",
        "opacity": 0.5
      },
      "encoding": {
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative"
        }
      }
    }
  ],
  "config": {
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "titleFontWeight": 600,
      "titleColor": "#1f2421",
      "labelColor": "#3a4540",
      "gridColor": "#e8e6e1"
    },
    "view": {
      "stroke": null
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 22,
      "anchor": "start",
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18
    }
  },
  "padding": {
    "left": 70,
    "right": 140,
    "top": 10,
    "bottom": 45
  }
}
