{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Palm expansion and forest loss overlap, but later years drift down",
    "subtitle": "Connected annual path, 2001–2024: planted area on x-axis and tree-cover loss on y-axis.",
    "anchor": "start"
  },
  "width": "container",
  "height": 520,
  "data": {
    "url": "data/area_vs_loss_yearly.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.planted_area_Mha) && isValid(datum.forest_loss_kha)"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "color": "#6b7570",
        "opacity": 0.45,
        "strokeWidth": 2,
        "interpolate": "linear"
      },
      "encoding": {
        "x": {
          "field": "planted_area_Mha",
          "type": "quantitative",
          "scale": {
            "zero": false,
            "nice": true
          },
          "title": "Malaysia's oil palm planted area (million hectares)",
          "axis": {
            "grid": true,
            "gridColor": "#eeeeee",
            "tickCount": 5,
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative",
          "title": "Tree cover loss that year (thousand hectares)",
          "axis": {
            "grid": true,
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "order": {
          "field": "year",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "planted_area_Mha",
          "type": "quantitative",
          "axis": {
            "tickCount": 5,
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative",
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "size": {
          "value": 150
        },
        "opacity": {
          "value": 0.88
        },
        "color": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "scheme": "viridis"
          },
          "title": "Year",
          "legend": {
            "orient": "right",
            "gradientLength": 200,
            "format": "d",
            "labelColor": "#3a4540",
            "titleColor": "#1f2421"
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "planted_area_Mha",
            "type": "quantitative",
            "title": "Planted area (Mha)",
            "format": ".2f"
          },
          {
            "field": "forest_loss_kha",
            "type": "quantitative",
            "title": "Forest loss (000 ha)",
            "format": ",.0f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "x": 3.5,
            "y": 332.81,
            "x2": 3.72,
            "y2": 385
          },
          {
            "x": 5.39,
            "y": 646.03,
            "x2": 4.83,
            "y2": 715
          },
          {
            "x": 5.61,
            "y": 282.53,
            "x2": 5.3,
            "y2": 210
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#1f2421",
        "strokeWidth": 1,
        "opacity": 0.65
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "x2": {
          "field": "x2",
          "type": "quantitative"
        },
        "y2": {
          "field": "y2",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x": 3.72,
            "y": 385,
            "label": "Start\n2001",
            "align": "left"
          },
          {
            "x": 4.83,
            "y": 715,
            "label": "Peak-loss period\n2012–2014",
            "align": "right"
          },
          {
            "x": 5.3,
            "y": 210,
            "label": "Latest\n2024",
            "align": "right"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": 700,
        "lineBreak": "\n",
        "color": "#1f2421",
        "align": "left"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2001 || datum.year == 2012 || datum.year == 2014 || datum.year == 2024"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 190,
        "stroke": "#1f2421",
        "strokeWidth": 1.4
      },
      "encoding": {
        "x": {
          "field": "planted_area_Mha",
          "type": "quantitative",
          "axis": {
            "tickCount": 5,
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "forest_loss_kha",
          "type": "quantitative",
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "color": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "scheme": "viridis"
          },
          "legend": {
            "labelColor": "#3a4540",
            "titleColor": "#1f2421"
          }
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleFontWeight": 500,
      "titleColor": "#1f2421",
      "grid": true,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "top": 18,
    "right": 110,
    "bottom": 42,
    "left": 8
  }
}
