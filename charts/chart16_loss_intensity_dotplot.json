{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Relative forest-loss intensity by state",
    "subtitle": "Total 2001–2024 tree-cover loss as a share of 2000 tree-cover extent.",
    "anchor": "start"
  },
  "width": "container",
  "height": 430,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "right": 80,
    "top": 18,
    "bottom": 30,
    "left": 8
  },
  "data": {
    "url": "data/state_loss_intensity.csv"
  },
  "transform": [
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "total_loss_2001_2024",
          "as": "national_loss"
        },
        {
          "op": "sum",
          "field": "tree_cover_extent_2000",
          "as": "national_extent"
        }
      ]
    },
    {
      "calculate": "datum.national_loss / datum.national_extent * 100",
      "as": "national_avg_pct"
    },
    {
      "calculate": "format(datum.loss_intensity_pct, '.1f') + '%' + (datum.state == 'Sabah' ? ' · Sabah hotspot' : (datum.state == 'Sarawak' ? ' · Sarawak hotspot' : ''))",
      "as": "intensity_label"
    },
    {
      "calculate": "datum.total_loss_2001_2024 / 1000",
      "as": "loss_kha"
    },
    {
      "filter": "isValid(datum.loss_kha)"
    },
    {
      "calculate": "datum.tree_cover_extent_2000 / 1000000",
      "as": "extent_Mha"
    }
  ],
  "layer": [
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "max",
              "field": "national_avg_pct",
              "as": "national_avg_pct"
            }
          ]
        }
      ],
      "mark": {
        "type": "rule",
        "color": "#6b7570",
        "strokeDash": [
          4,
          4
        ],
        "strokeWidth": 1.3,
        "opacity": 0.8
      },
      "encoding": {
        "x": {
          "field": "national_avg_pct",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "max",
              "field": "national_avg_pct",
              "as": "national_avg_pct"
            }
          ]
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 10,
        "dy": -8,
        "font": "Inter",
        "fontSize": 11,
        "fontStyle": "italic",
        "color": "#4b5563",
        "fontWeight": 700,
        "y": 8
      },
      "encoding": {
        "x": {
          "field": "national_avg_pct",
          "type": "quantitative"
        },
        "text": {
          "value": "National average"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 155,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "loss_intensity_pct",
          "type": "quantitative",
          "title": "Tree-cover loss as share of 2000 extent (%)",
          "scale": {
            "domain": [
              0,
              65
            ]
          },
          "axis": {
            "format": ".0f",
            "grid": true,
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "loss_intensity_pct",
            "order": "descending"
          },
          "axis": {
            "labelLimit": 130,
            "labelColor": "#3a4540",
            "labelAlign": "right",
            "labelPadding": 8
          }
        },
        "color": {
          "condition": [
            {
              "test": "datum.state == 'Sabah'",
              "value": "#2d5a3d"
            },
            {
              "test": "datum.state == 'Sarawak'",
              "value": "#c25e1e"
            }
          ],
          "value": "#8f9792"
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "loss_kha",
            "type": "quantitative",
            "format": ",.0f",
            "title": "Total loss (000 ha)"
          },
          {
            "field": "extent_Mha",
            "type": "quantitative",
            "format": ".2f",
            "title": "2000 tree-cover extent (Mha)"
          },
          {
            "field": "loss_intensity_pct",
            "type": "quantitative",
            "format": ".1f",
            "title": "Loss intensity (%)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 9,
        "font": "Inter",
        "fontSize": 10.5,
        "fontWeight": 600,
        "color": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "loss_intensity_pct",
          "type": "quantitative",
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          }
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "loss_intensity_pct",
            "order": "descending"
          },
          "axis": {
            "labelColor": "#3a4540",
            "labelAlign": "right",
            "labelPadding": 8
          }
        },
        "text": {
          "field": "intensity_label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x": 43,
            "y": "Labuan",
            "label": "Hotspots coloured:\nSabah green, Sarawak orange"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "font": "Inter",
        "fontSize": 11,
        "fontStyle": "italic",
        "lineBreak": "\n",
        "color": "#3a4540"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "nominal"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleFontWeight": 500,
      "titleColor": "#1f2421",
      "grid": true,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "titleFont": "Inter",
      "titleFontSize": 12,
      "labelColor": "#3a4540",
      "titleColor": "#1f2421"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    }
  }
}
