{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Economic Gain vs Environmental Bill",
    "subtitle": [
      "Malaysia, 2001–2024: export earnings above zero; tree-cover loss below zero.",
      "Units: exports = RM bn; forest loss = kha ÷ 5 for direction, not equivalence."
    ],
    "anchor": "start"
  },
  "width": "container",
  "height": 420,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "top": 24,
    "bottom": 36,
    "left": 10,
    "right": 20
  },
  "data": {
    "url": "data/malaysia_economy_yearly.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum.export_value_RMbn)",
      "as": "exports"
    },
    {
      "calculate": "toNumber(datum.forest_loss_kha)",
      "as": "loss_kha"
    },
    {
      "filter": "datum.exports != null && isFinite(datum.exports) && datum.loss_kha != null && isFinite(datum.loss_kha)"
    },
    {
      "calculate": "-datum.loss_kha / 5",
      "as": "loss_neg"
    },
    {
      "calculate": "toNumber(datum.year) == 2008 ? '2008: GFC' : (toNumber(datum.year) == 2022 ? '2022: export record' : null)",
      "as": "export_annotation"
    }
  ],
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {
        "labelAngle": 0,
        "labelOverlap": "greedy",
        "labelFont": "Inter",
        "labelFontSize": 11,
        "labelColor": "#333333"
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#1f2421",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "datum": 0
        }
      }
    },
    {
      "mark": {
        "type": "bar",
        "color": "#c25e1e",
        "cornerRadiusEnd": 2,
        "opacity": 0.9
      },
      "encoding": {
        "y": {
          "field": "exports",
          "type": "quantitative",
          "title": null,
          "axis": {
            "labelExpr": "datum.value >= 0 ? format(datum.value, '.0f') : '−' + format(-datum.value * 5, '.0f')",
            "grid": true,
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540"
          },
          "scale": {
            "domain": [
              -150,
              150
            ]
          }
        },
        "opacity": {
          "value": 0.9
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "exports",
            "type": "quantitative",
            "format": ".1f",
            "title": "Exports (RM bn)"
          },
          {
            "field": "loss_kha",
            "type": "quantitative",
            "format": ".1f",
            "title": "Forest loss (kha)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "bar",
        "color": "#2d5a3d",
        "cornerRadiusEnd": 2,
        "opacity": 0.9
      },
      "encoding": {
        "y": {
          "field": "loss_neg",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "loss_kha",
            "type": "quantitative",
            "format": ".1f",
            "title": "Forest loss (kha)"
          },
          {
            "field": "exports",
            "type": "quantitative",
            "format": ".1f",
            "title": "Exports (RM bn)"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "year": "2001",
            "exports": 14.4,
            "order": 1
          },
          {
            "year": "2022",
            "exports": 137.9,
            "order": 2
          }
        ]
      },
      "mark": {
        "type": "line",
        "color": "#6b7570",
        "strokeDash": [
          3,
          3
        ],
        "strokeWidth": 1.1,
        "opacity": 0.45
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "exports",
          "type": "quantitative",
          "axis": {
            "gridColor": "#eeeeee",
            "labelColor": "#3a4540",
            "labelExpr": "datum.value >= 0 ? format(datum.value, '.0f') : '−' + format(-datum.value * 5, '.0f')"
          }
        },
        "order": {
          "field": "order",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": "2022",
            "y": 145,
            "label": "Export growth\n2022 record"
          }
        ]
      },
      "mark": {
        "type": "text",
        "dy": -6,
        "fontSize": 11,
        "fontWeight": 700,
        "lineBreak": "\n",
        "font": "Inter",
        "color": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": "2014",
            "y": -129.206,
            "y2": -145
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#1f2421",
        "strokeWidth": 1,
        "opacity": 0.7
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "y2": {
          "field": "y2",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": "2014",
            "y": -138,
            "label": "Forest-loss peak\n2014"
          }
        ]
      },
      "mark": {
        "type": "text",
        "dy": 8,
        "fontSize": 11,
        "fontWeight": 700,
        "lineBreak": "\n",
        "font": "Inter",
        "color": "#1f2421"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "domain": false,
      "ticks": false,
      "labelFont": "Inter",
      "labelFontSize": 12,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleFontWeight": 500,
      "titleColor": "#1f2421",
      "grid": true,
      "gridColor": "#eeeeee",
      "gridOpacity": 0.75
    },
    "legend": {
      "labelFont": "Inter",
      "labelFontSize": 11,
      "labelColor": "#3a4540",
      "titleFont": "Inter",
      "titleFontSize": 12,
      "titleColor": "#1f2421"
    },
    "title": {
      "font": "Fraunces",
      "fontSize": 18,
      "fontWeight": 600,
      "color": "#1f2421",
      "subtitleFont": "Inter",
      "subtitleFontSize": 13,
      "subtitleColor": "#4b5563",
      "subtitleLineHeight": 18,
      "anchor": "start"
    }
  }
}